{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "lib": ["DOM", "ES2022"],
    "noEmitOnError": false,
    "noImplicitAny": true,
    "preserveConstEnums": true,
    "strict": true,
    "strictNullChecks": true,
    "declaration": true,
    "declarationMap": true,
    "module": "commonjs",
    "target": "ES2022",
    "skipLibCheck": true,
    "jsx": "react-jsx"
  }
}
