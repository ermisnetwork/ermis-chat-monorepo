{
  "name": "ermis-chat-sdk",
  "version": "1.0.0",
  "description": "Ermis Chat SDK",
  "author": "Ermis",
  "homepage": "https://ermis.network/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ermisnetwork/ermis-chat-sdk"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "browser": {
    "./dist/index.mjs": "./dist/index.browser.mjs",
    "./dist/index.cjs": "./dist/index.browser.cjs"
  },
  "react-native": {
    "./dist/index.mjs": "./dist/index.browser.mjs",
    "./dist/index.cjs": "./dist/index.browser.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "jsdelivr": "./dist/index.browser.full-bundle.min.js",
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "chat",
    "messaging",
    "conversation",
    "react",
    "ermis",
    "ermis.network"
  ],
  "files": [
    "/dist",
    "/src",
    "readme.md",
    "license"
  ],
  "dependencies": {
    "@types/event-source-polyfill": "^1.0.5",
    "@types/jsonwebtoken": "~9.0.0",
    "@types/ws": "^7.4.0",
    "axios": "^1.6.0",
    "base64-js": "^1.5.1",
    "event-source-polyfill": "^1.0.31",
    "form-data": "^4.0.0",
    "isomorphic-ws": "^4.0.1",
    "jsonwebtoken": "~9.0.0",
    "ws": "^7.4.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^16.0.2",
    "@commitlint/config-conventional": "^16.0.0",
    "@types/base64-js": "^1.3.0",
    "@types/chai": "^4.2.15",
    "@types/chai-arrays": "^2.0.0",
    "@types/chai-as-promised": "^7.1.4",
    "@types/chai-like": "^1.1.1",
    "@types/mocha": "^9.0.0",
    "@types/node": "^16.11.11",
    "@types/sinon": "^10.0.6",
    "chai": "^4.3.4",
    "chai-arrays": "^2.2.0",
    "chai-as-promised": "^7.1.1",
    "chai-like": "^1.1.1",
    "chai-sorted": "^0.2.0",
    "dotenv": "^8.2.0",
    "eslint": "7.21.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-sonarjs": "^0.6.0",
    "husky": "^4.3.8",
    "lint-staged": "^15.2.2",
    "mocha": "^9.1.3",
    "nyc": "^15.1.0",
    "prettier": "^2.2.1",
    "sinon": "^12.0.1",
    "standard-version": "^9.3.2",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "start": "yarn run compile -w",
    "compile": "tsup",
    "build": "rm -rf dist && tsup",
    "types": "tsc --noEmit",
    "prettier": "prettier --check '**/*.{js,ts,md,css,scss,json}' .eslintrc.json .prettierrc .babelrc",
    "prettier-fix": "npx prettier --write '**/*.{js,ts,md,css,scss,json}' .eslintrc.json .prettierrc .babelrc",
    "test-types": "node test/typescript/index.js && tsc --esModuleInterop true --noEmit true --strictNullChecks true --noImplicitAny true --strict true test/typescript/*.ts",
    "eslint": "eslint '**/*.{js,md,ts}' --max-warnings 0 --ignore-path ./.eslintignore",
    "eslint-fix": "npx eslint --fix '**/*.{js,md,ts}' --max-warnings 0 --ignore-path ./.eslintignore",
    "test-unit": "NODE_ENV=test mocha --exit --bail --timeout 20000 --require ./babel-register test/unit/*.js",
    "test-coverage": "nyc yarn test-unit",
    "test": "yarn test-unit",
    "testwatch": "NODE_ENV=test nodemon ./node_modules/.bin/mocha --timeout 20000 --require test-entry.js test/test.js",
    "lint": "yarn run prettier && yarn run eslint",
    "lint-fix": "yarn run prettier-fix && yarn run eslint-fix",
    "fix-staged": "lint-staged --config .lintstagedrc.fix.json --concurrent 1",
    "prepare": "yarn run build",
    "preversion": "yarn && yarn lint && yarn test-unit",
    "version": "git add yarn.lock",
    "postversion": "git push && git push --tags && npm publish"
  },
  "engines": {
    "node": ">=16"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "bugs": {
    "url": "https://github.com/ermisnetwork/ermis-chat-sdk/issues"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
