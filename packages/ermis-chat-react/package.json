  },
  "files": [
    "/dist",
    "/src"
  ],
  "dependencies": {
    "@ermis-network/ermis-chat-sdk": "1.0.3",
    "virtua": "^0.48.8"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "tsup --watch"
  }
