{
  "name": "@ermis-network/ermis-chat-react",
  "version": "1.0.3",
  "description": "React UI components for Ermis Chat",
  "author": "Ermis",
  "homepage": "https://ermis.network/",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
